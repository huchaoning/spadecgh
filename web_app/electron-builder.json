{
    "productName": "SpadeCGH",
    "asar": true,
    "afterPack": "afterPack.js",
    "directories": {
        "output": "out"
    },
    "files": [
        "dist/**/*",
        "main.js",
        "package.json",
        "icons/**/*",
        "!node_modules/**/*"
    ],
    "win": {
        "target": [
            {
                "target": "nsis",
                "arch": [
                    "x64"
                ]
            },
            {
                "target": "zip",
                "arch": [
                    "x64"
                ]
            }
        ],
        "icon": "icons/icon.ico"
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "runAfterFinish": true,
        "deleteAppDataOnUninstall": true,
        "installerLanguages": [
            "en_US"
        ]
    },
    "mac": {
        "target": [
            {
                "target": "dmg",
                "arch": [
                    "universal"
                ]
            },
            {
                "target": "zip",
                "arch": [
                    "universal"
                ]
            }
        ],
        "identity": null,
        "icon": "icons/icon.icns"
    },
    "linux": {
        "target": [
            {
                "target": "AppImage",
                "arch": [
                    "x64"
                ]
            }
        ],
        "icon": "icons/icon.png"
    }
}